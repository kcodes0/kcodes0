{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "konacodes",
  "compatibility_date": "2025-04-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    { "pattern": "kcodes.me/*", "zone_name": "kcodes.me" },
    { "pattern": "www.kcodes.me/*", "zone_name": "kcodes.me" }
  ]
}
